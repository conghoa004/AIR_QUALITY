<link rel="stylesheet" href="/css/admin/device-manager.css">

<div class="device-manager-page container-fluid">
    <div class="am-card p-2 p-sm-3">
        <!-- Toolbar -->
        <div class="am-toolbar pb-2">
            <div class="row w-100 g-3 align-items-center">
                <div class="col-12 col-sm-7 col-md-6">
                    <div class="am-search flex-grow-1">
                        <div class="input-group input-group-sm am-pill p-1">
                            <span class="input-group-text ps-3">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" id="tableSearch" class="form-control pe-3"
                                placeholder="Tìm nhanh trong bảng..." />
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-5 col-md-6 text-sm-end">
                    <div class="d-flex align-items-center justify-content-end gap-2">
                        <i class="bi bi-cpu-fill text-primary me-2" style="font-size: 1.2rem;"></i>

                        <span class="badge bg-primary fs-6 px-3 py-2">
                            <%= devices.length %> trạm
                        </span>

                        <!-- Nút chuyển sang mô phỏng -->
                        <span class="badge bg-success fs-6 px-3 py-2" style="cursor: pointer;"
                            onclick="window.open('/simulator', '_blank')">
                            <i class="bi bi-display"></i> Simulator
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="am-table-wrap mt-2">
            <div class="table-responsive">
                <table id="deviceTable" class="table table-striped align-middle mb-0" style="width:100%">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Vị trí</th>
                            <th>Last AQI</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% devices.forEach(device=> { %>
                            <tr>
                                <td>
                                    <%= device.sensor_id %>
                                </td>
                                <td>
                                    <%= device.area %> - <%= device.location_name %>
                                </td>
                                <td>
                                    <%= device.last_aqi_total !==undefined ? device.last_aqi_total : "-" %>
                                </td>
                                <td>
                                    <% if (device.status==="offline" ) { %>
                                        <span class="badge bg-secondary">Offline</span>
                                        <% } else { %>
                                            <span class="badge bg-success">
                                                <%= device.status %>
                                            </span>
                                            <% } %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- jQuery (bắt buộc cho DataTables) -->
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>

<!-- DataTables CSS & JS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css">
<script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

