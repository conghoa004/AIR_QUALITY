{
  "expo": {
    "name": "Air Quality",
    "slug": "air-quality",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "airquality",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "App cần vị trí để xác định trạm đo gần nhất",
        "NSLocationAlwaysUsageDescription": "App cần vị trí luôn bật để gửi dữ liệu khi chạy nền",
        "UIBackgroundModes": ["location"],
        "NSPhotoLibraryUsageDescription": "Ứng dụng cần truy cập thư viện ảnh để cập nhật ảnh đại diện"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFCCFF",
        "foregroundImage": "./assets/images/logo.png"
        // "backgroundImage": "./assets/images/android-icon-background.png",
        // "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.hoaze.airquality.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "READ_MEDIA_IMAGES"
      ],
      "foregroundService": {
        "notificationTitle": "App đang gửi vị trí",
        "notificationBody": "Đang gửi vị trí nền",
        "notificationColor": "#FFCCFF"
      },
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "@react-native-google-signin/google-signin",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9deabfd3-7129-4167-983e-90fe743cfacc"
      }
    },
    "owner": "conghoa"
  }
}
